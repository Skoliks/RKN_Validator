APP_NAME=Site Compliance Checker
APP_ENV=local
LOG_LEVEL=INFO
MAX_PAGES_PER_SITE=5
REQUEST_TIMEOUT_SECONDS=10
MAX_REQUESTS_PER_SITE=15
ENABLE_BROWSER_CHECK=true
BROWSER_TIMEOUT_SECONDS=15
BROWSER_NAVIGATION_WAIT_UNTIL=networkidle
BROWSER_MAX_NETWORK_REQUESTS=200
ENABLE_COOKIE_INTERACTION_CHECK=false
COOKIE_INTERACTION_TIMEOUT_SECONDS=10
COOKIE_INTERACTION_TEXT_LIMIT=3000
